<?xml version="1.0" encoding="UTF-8"?>
<!-- plugin.dtd lives in OXYGEN_INSTALL_DIR/plugins/plugin.dtd -->
<plugin
    id="ch.kr.anton.oxy"
    name="anton-oxy"
    description="Searches actors and places live in Anton and writes the id (e.g. {slug}-actors-123) into a configurable attribute (default @ref) of the element under the caret."
    version="1.3.1"
    vendor="K-R / UZH ZDE"
    class="ch.kr.anton.oxy.AntonOxyPlugin"
    classLoaderType="preferReferencedResources">

    <runtime>
        <librariesFolder name="lib/"/>
    </runtime>

    <extension type="WorkspaceAccess"
               class="ch.kr.anton.oxy.AntonOxyPluginExtension"/>

    <toolbar id="AntonOxyToolbarID" initialSide="NORTH" initialRow="2"/>
</plugin>
